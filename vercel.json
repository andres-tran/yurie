{
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/static/(.*)",
      "destination": "/api/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "runtime": "python3.9"
    },
    "api/health.py": {
      "maxDuration": 10,
      "runtime": "python3.9"
    }
  }
}